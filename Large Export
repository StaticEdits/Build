--------------------------------------------------
-- HELPERS
--------------------------------------------------
local allowedItems = {"Building Block","Grass","Glass Pane"}

local function isAllowedItem(name)
	for _,a in ipairs(allowedItems) do
		if string.find(name,a) then return true end
	end
end

local function cfToString(cf)
	local t = {cf:GetComponents()}
	for i,v in ipairs(t) do t[i] = string.format("%.5f",v) end
	return table.concat(t,",")
end

local function sizeToString(size)
	return table.concat({size.X,size.Y,size.Z},",")
end

local function colorToHex(c)
	local r = math.floor(c.R*255+0.5)
	local g = math.floor(c.G*255+0.5)
	local b = math.floor(c.B*255+0.5)
	return string.format("%02x%02x%02x",r,g,b)
end

local function getPlot(name)
	local playerName = name ~= "" and name or LocalPlayer.Name
	for _,plot in ipairs(Workspace.Property.Plots:GetChildren()) do
		local empty = plot:FindFirstChild("Empty")
		if empty and empty:FindFirstChild("Owner") and empty.Owner.Value == playerName then
			return empty
		end
	end
end

--------------------------------------------------
-- EXPORT
--------------------------------------------------
local function exportBlueprint()
	local plot = getPlot(playerBox.Text)
	if not plot then warn("No plot") return end

	local terrain = plot:FindFirstChild("Terrain") and plot.Terrain:FindFirstChild("Grass")
	local furniture = plot:FindFirstChild("ActiveAssets") and plot.ActiveAssets:FindFirstChild("Furniture")

	if not terrain or not furniture then
		warn("Missing data")
		return
	end

	local blocks = {}

	for _,model in ipairs(furniture:GetChildren()) do
		local item = model:FindFirstChild("Item")
		local color = model:FindFirstChild("Color")

		if item and color and isAllowedItem(item.Value) then
			local id

			for _,f in ipairs(RSFurniture:GetChildren()) do
				if f:IsA("ImageButton") and string.lower(f.Name) == string.lower(item.Value) and f:FindFirstChild("Id") then
					id = f.Id.Value
					break
				end
			end

			if not id then continue end

			for _,part in ipairs(model:GetDescendants()) do
				if part:IsA("BasePart") then
					local rel = terrain.CFrame:ToObjectSpace(part.CFrame)

					table.insert(blocks, table.concat({
						id,
						cfToString(rel),
						model.Color.Value,
						sizeToString(part.Size),
						colorToHex(part.Color)
					},"|"))
				end
			end
		end
	end

	totalPartsLabel.Text = "Total parts: "..#blocks

	local partsPerBox = 800
	local index = 1

	for i = 1, #blueprintBoxes do
		local chunk = {}

		for j = 1, partsPerBox do
			if index > #blocks then break end
			table.insert(chunk, blocks[index])
			index += 1
		end

		blueprintBoxes[i].Text = table.concat(chunk,";")
		blueprintLabels[i].Text = "Box "..i..": "..#chunk.." parts"
	end

	print("Export complete:", #blocks)
end

exportButton.MouseButton1Click:Connect(exportBlueprint)
