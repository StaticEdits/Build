		or Color3.fromRGB(170,0,0)
end)

--// CLICK SELECT
Mouse.Button1Down:Connect(function()
	if not Enabled then
		return
	end

	local ctrl =
		UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
		or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)

	if ctrl then
		Dragging = true
		DragStart = UserInputService:GetMouseLocation()

		SelectionFrame.Visible = true
		SelectionFrame.Position = UDim2.fromOffset(DragStart.X, DragStart.Y)
		SelectionFrame.Size = UDim2.new(0,0,0,0)
	end
end)

Mouse.Button1Up:Connect(function()
	if not Enabled then
		return
	end

	local ctrl =
		UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
		or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)

	local mousePos = UserInputService:GetMouseLocation()

	-- CTRL CLICK
	if ctrl and DragStart then
		local distance = (Vector2.new(mousePos.X, mousePos.Y)
			- Vector2.new(DragStart.X, DragStart.Y)).Magnitude

		if distance < 8 then
			SelectionFrame.Visible = false
			Dragging = false

			local target = Mouse.Target
			if not target then
				return
			end

			local model = getFurnitureModel(target)

			if model then
				toggleSelection(model)
			end

			return
		end
	end

	-- NORMAL CLICK
	if not ctrl then
		local target = Mouse.Target

		if not target then
			return
		end

		clearSelection()

		local model = getFurnitureModel(target)

		if model then
			toggleSelection(model)
		end

		return
	end

	-- BOX SELECT
	if Dragging and DragStart then
		Dragging = false
		SelectionFrame.Visible = false

		local minX = math.min(DragStart.X, mousePos.X)
		local minY = math.min(DragStart.Y, mousePos.Y)
		local maxX = math.max(DragStart.X, mousePos.X)
		local maxY = math.max(DragStart.Y, mousePos.Y)

		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("BasePart") then
				local pos, visible = Camera:WorldToViewportPoint(obj.Position)

				if visible then
					if pos.X >= minX and pos.X <= maxX
					and pos.Y >= minY and pos.Y <= maxY then

						local model = getFurnitureModel(obj)

						if model and not table.find(SelectedModels, model) then
							table.insert(SelectedModels, model)
							addHighlight(model)
						end
					end
				end
			end
		end
	end
end)

--// BOX UPDATE
RunService.RenderStepped:Connect(function()
	if not Dragging or not DragStart then
		return
	end

	local mousePos = UserInputService:GetMouseLocation()

	local minX = math.min(DragStart.X, mousePos.X)
	local minY = math.min(DragStart.Y, mousePos.Y)
	local maxX = math.max(DragStart.X, mousePos.X)
	local maxY = math.max(DragStart.Y, mousePos.Y)

	SelectionFrame.Position = UDim2.fromOffset(minX, minY)
	SelectionFrame.Size = UDim2.fromOffset(
		maxX - minX,
		maxY - minY
	)
end)

--// KEYBINDS
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then
		return
	end

	-- APPLY PAINT
	if input.KeyCode == Enum.KeyCode.L then
		applyToSelection()
	end

	-- CLEAR
	if input.KeyCode == Enum.KeyCode.Backspace then
		clearSelection()
	end

	-- TOGGLE
	if input.KeyCode == Enum.KeyCode.P then
		Enabled = not Enabled

		ToggleButton.Text =
			Enabled and "Enabled"
			or "Disabled"

		ToggleButton.BackgroundColor3 =
			Enabled and Color3.fromRGB(0,170,0)
			or Color3.fromRGB(170,0,0)
	end
end)

