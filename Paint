--// FUNCTIONS

local function hexToColor3(hex)
	hex = hex:gsub("#","")

	if #hex ~= 6 then
		return Color3.new(1,1,1)
	end

	local r = tonumber(hex:sub(1,2),16) or 255
	local g = tonumber(hex:sub(3,4),16) or 255
	local b = tonumber(hex:sub(5,6),16) or 255

	return Color3.fromRGB(r,g,b)
end

local function updatePreview()
	Preview.BackgroundColor3 = hexToColor3(ColorBox.Text)
end

ColorBox:GetPropertyChangedSignal("Text"):Connect(updatePreview)

local function getPlot(name)
	local playerName = (name ~= "" and name) or LocalPlayer.Name

	for _, plot in ipairs(Workspace.Property.Plots:GetChildren()) do
		for _, obj in ipairs(plot:GetDescendants()) do
			if obj.Name == "Owner" then
				if obj:IsA("ObjectValue") and obj.Value and obj.Value.Name == playerName then
					return obj.Parent
				elseif obj:IsA("StringValue") and obj.Value == playerName then
					return obj.Parent
				end
			end
		end
	end
end

local Plot = getPlot("")

local function clearSelection()
	for _, highlight in pairs(HighlightMap) do
		if highlight then
			highlight:Destroy()
		end
	end

	table.clear(SelectedModels)
	table.clear(HighlightMap)
end

local function addHighlight(model)
	if HighlightMap[model] then
		return
	end

	local highlight = Instance.new("Highlight")
	highlight.FillColor = Color3.fromRGB(0,170,255)
	highlight.OutlineColor = Color3.new(1,1,1)
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = model

	HighlightMap[model] = highlight
end

local function removeHighlight(model)
	if HighlightMap[model] then
		HighlightMap[model]:Destroy()
		HighlightMap[model] = nil
	end
end

local function getFurnitureModel(part)
	local current = part

	while current and current ~= Workspace do
		if current:IsA("Model") and current:GetAttribute("SerialId") then
			return current
		end

		current = current.Parent
	end

	return nil
end

local function toggleSelection(model)
	if not model then
		return
	end

	local index = table.find(SelectedModels, model)

	if index then
		table.remove(SelectedModels, index)
		removeHighlight(model)
	else
		table.insert(SelectedModels, model)
		addHighlight(model)
	end
end

local function getFurnitureId(serialRaw)
	if typeof(serialRaw) == "string" then
		local split = string.split(serialRaw, "_")
		return tonumber(split[#split])
	end

	return tonumber(serialRaw)
end

local function applyColor(model)
	local serialRaw = model:GetAttribute("SerialId")
	if not serialRaw then
		return
	end

	local serialId = getFurnitureId(serialRaw)
	if not serialId then
		return
	end

	local hex = ColorBox.Text:gsub("#","")
	local materialId = tonumber(MaterialBox.Text) or 16

	pcall(function()
		ChangeColor:InvokeServer(
			serialId,
			Plot,
			{
				hex
			}
		)
	end)

	pcall(function()
		ChangeTexture:InvokeServer(
			serialId,
			Plot,
			1,
			materialId
		)
	end)
end

local function applyToSelection()
	for _, model in ipairs(SelectedModels) do
		applyColor(model)
	end
end

