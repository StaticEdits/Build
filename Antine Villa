local function getBlock(material)
	return materialMap[material] or {name="BB_Building Block_White", color=Color3.fromRGB(255,192,203), colorName="Pink"}
end

--====================================================
-- BLUEPRINT STRING (EXAMPLE)
--====================================================
local blueprintData = [[
Ceiling|62.745598,63.303719,-42.002686|-0.000000,1.570796,0.000000|14.000000,2.200000,12.300000|SmoothPlastic
]]

--====================================================
-- SIZE HELPERS
--====================================================
local function sizeToKeyExact(size)
	return size.X..","..size.Y..","..size.Z
end

local function sizeToKeyGUI(size)
	local function round1(num)
		return math.floor(num*10 + 0.5)/10
	end
	return round1(size.X)..","..round1(size.Y)..","..round1(size.Z)
end

local function groupKey(size,material)
	return sizeToKeyExact(size).."|"..material
end

--====================================================
-- BLUEPRINT TABLE
--====================================================
local blueprint = {}

local function addSlot(size,pos,rot,material)
	local key = groupKey(size,material)
	blueprint[key] = blueprint[key] or {
		size = size,
		material = material,
		blockName = getBlock(material).name,
		blockColor = getBlock(material).color,
		colorName = getBlock(material).colorName,
		slots = {}
	}
	table.insert(blueprint[key].slots,{
		pos = pos,
		rot = rot,
		filled = false
	})
end

--====================================================
-- PARSE BLUEPRINT
--====================================================
for line in blueprintData:gmatch("[^;]+") do
	local part,posStr,rotStr,sizeStr,matStr =
		line:match("([^|]+)|([^|]+)|([^|]+)|([^|]+)|?(.*)")
	if part and posStr and rotStr and sizeStr then
		local px,py,pz = posStr:match("([^,]+),([^,]+),([^,]+)")
		local rx,ry,rz = rotStr:match("([^,]+),([^,]+),([^,]+)")
		local sx,sy,sz = sizeStr:match("([^,]+),([^,]+),([^,]+)")

		local pos = Vector3.new(tonumber(px),tonumber(py),tonumber(pz))
		local rot = Vector3.new(tonumber(rx),tonumber(ry),tonumber(rz))
		local size = Vector3.new(tonumber(sx),tonumber(sy),tonumber(sz))

		if not matStr or matStr == "" then matStr = "SmoothPlastic" end

		addSlot(size,pos,rot,matStr)
	end
end

--====================================================
-- CRASH RECOVERY
--====================================================
local function vecClose(a,b,t)
	return math.abs(a.X-b.X)<=t
	   and math.abs(a.Y-b.Y)<=t
	   and math.abs(a.Z-b.Z)<=t
end

local function recoverExisting()
	for _,model in ipairs(furnitureFolder:GetChildren()) do
		if not model.Name:find("BB_") then continue end
		local block = model:FindFirstChild("Block_Color1")
		if not block then continue end

		local relative = grass.CFrame:ToObjectSpace(block.CFrame)
		local pos = relative.Position
		local rx,ry,rz = relative:ToOrientation()
		local rot = Vector3.new(rx,ry,rz)
		local size = block.Size

		for _,group in pairs(blueprint) do
			if group.blockName ~= model.Name then continue end
			if sizeToKeyExact(group.size) ~= sizeToKeyExact(size) then continue end

			for _,slot in ipairs(group.slots) do
				if slot.filled then continue end
				if vecClose(pos,slot.pos,0.05) and vecClose(rot,slot.rot,0.02) then
					slot.filled = true
					break
				end
			end
		end
	end
end

recoverExisting()

