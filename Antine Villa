--====================================================
-- REFRESH GUI
--====================================================
local function refreshGUI()
	for _,child in ipairs(frame:GetChildren()) do
		if child:IsA("TextLabel") and child ~= title then
			child:Destroy()
		end
	end

	for _,group in pairs(blueprint) do
		local remaining = 0
		for _,slot in ipairs(group.slots) do
			if not slot.filled then remaining += 1 end
		end
		if remaining > 0 then
			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1,0,0,25)
			label.BackgroundTransparency = 1
			label.TextColor3 = group.blockColor
			label.TextScaled = true
			label.Text = group.colorName.." | "..sizeToKey(group.size).." x"..remaining
			label.Parent = frame
		end
	end
end

--====================================================
-- BILLBOARD THAT UPDATES WITH SIZE
--====================================================
local function addSizeBillboard(block)
	if block:FindFirstChild("SizeBillboard") then return end
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "SizeBillboard"
	billboard.Adornee = block
	billboard.Size = UDim2.new(0,120,0,40)
	billboard.StudsOffset = Vector3.new(0,block.Size.Y/2+0.5,0)
	billboard.AlwaysOnTop = true
	billboard.Parent = block

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,1,0)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1,1,1)
	label.TextScaled = true
	label.Text = sizeToKey(block.Size)
	label.Parent = billboard

	-- Update text whenever size changes
	block:GetPropertyChangedSignal("Size"):Connect(function()
		label.Text = sizeToKey(block.Size)
	end)
end

local function removeSizeBillboard(block)
	local bb = block:FindFirstChild("SizeBillboard")
	if bb then bb:Destroy() end
end

--====================================================
-- ASSIGN SLOT
--====================================================
local function assignSlot(block,group)
	-- Skip green blocks
	if block.Color == Color3.fromRGB(0,255,0) then return end

	for _,slot in ipairs(group.slots) do
		if not slot.filled and sizesMatch(block.Size,group.size) then
			local cf = grass.CFrame * CFrame.new(slot.pos) * CFrame.fromEulerAnglesXYZ(slot.rot.X, slot.rot.Y, slot.rot.Z)
			block.CFrame = cf
			block.Anchored = true
			slot.filled = true
			block.Color = Color3.fromRGB(0,255,0)
			removeSizeBillboard(block)
			refreshGUI()
			return
		end
	end
end

--====================================================
-- PROCESS MODEL
--====================================================
local function processModel(model)
	local block = model:FindFirstChild("Block_Color1")
	if not block then return end
	if block.Color == Color3.fromRGB(0,255,0) then return end

	for _,group in pairs(blueprint) do
		if model.Name == group.blockName then
			block.Color = group.blockColor

			-- Check if already in correct position
			for _,slot in ipairs(group.slots) do
				local targetCF = grass.CFrame * CFrame.new(slot.pos) * CFrame.fromEulerAnglesXYZ(slot.rot.X, slot.rot.Y, slot.rot.Z)
				if positionsMatch(block.Position,targetCF.Position) and rotationsMatch(block.Orientation,targetCF:ToOrientation()) then
					slot.filled = true
					block.Color = Color3.fromRGB(0,255,0)
					break
				end
			end

			-- Billboard shows size and updates live
			addSizeBillboard(block)
			break
		end
	end
end

for _,model in ipairs(furnitureFolder:GetChildren()) do
	processModel(model)
end
furnitureFolder.ChildAdded:Connect(processModel)

--====================================================
-- CTRL KEYBIND FOR MANUAL SNAP
--====================================================
local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
		for _,model in ipairs(furnitureFolder:GetChildren()) do
			local block = model:FindFirstChild("Block_Color1")
			if not block then continue end
			if block.Color == Color3.fromRGB(0,255,0) then continue end

			for _,group in pairs(blueprint) do
				for _,slot in ipairs(group.slots) do
					if not slot.filled and sizesMatch(block.Size,group.size) then
						assignSlot(block,group)
						break
					end
				end
			end
		end
	end
end)
