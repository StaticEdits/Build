--------------------------------------------------
-- FIND PLAYER HOUSE
--------------------------------------------------

local function GetHousePath()

	for _,plot in ipairs(workspace.Property.Plots:GetChildren()) do

		local owner = plot:FindFirstChild("Owner",true)

		if owner and owner:IsA("StringValue") and owner.Value == player.Name then
			return plot
		end

	end

end

local House = GetHousePath()
local Plot = House.Empty
local GrassCF = Plot.Terrain.Grass.CFrame

--------------------------------------------------
-- REMOTES
--------------------------------------------------

local PlaceFurniture = RS:WaitForChild("Relays"):WaitForChild("House"):WaitForChild("PlaceFurniture")
local ChangeSize = RS:WaitForChild("Relays"):WaitForChild("House"):WaitForChild("ChangeFurnitureSize")

--------------------------------------------------
-- GUI
--------------------------------------------------

local function CreateProgressGui(total)

	local gui = Instance.new("ScreenGui")
	gui.Name = "BlueprintPrinter"
	gui.ResetOnSpawn = false
	gui.Parent = player.PlayerGui

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0,200,0,50)
	frame.Position = UDim2.new(0.5,-100,0,50)
	frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
	frame.BorderSizePixel = 0
	frame.Parent = gui

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,1,0)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1,1,1)
	label.TextScaled = true
	label.Font = Enum.Font.SourceSansBold
	label.Text = "0 / "..total
	label.Parent = frame

	return gui,label

end

local function UpdateProgress(label,current,total)

	label.Text = current.." / "..total

end

local function RemoveGui(gui)

	task.wait(1)

	gui:Destroy()

end

--------------------------------------------------
-- PARSE BLUEPRINT
--------------------------------------------------

local function ParseBlueprint(str)

	local parts = {}

	for line in string.gmatch(str,"[^;]+") do

		local values = string.split(line,",")

		local type = values[1]

		local cf = {
			tonumber(values[2]),
			tonumber(values[3]),
			tonumber(values[4]),
			tonumber(values[5]),
			tonumber(values[6]),
			tonumber(values[7]),
			tonumber(values[8]),
			tonumber(values[9]),
			tonumber(values[10]),
			tonumber(values[11]),
			tonumber(values[12]),
			tonumber(values[13])
		}

		local size = {
			tonumber(values[14]),
			tonumber(values[15]),
			tonumber(values[16])
		}

		table.insert(parts,{
			type = type,
			cf = cf,
			size = size
		})

	end

	return parts

end

--------------------------------------------------
-- DECODE CFRAME
--------------------------------------------------

local function DecodeCF(t)

	return CFrame.new(
		t[1],t[2],t[3],
		t[4],t[5],t[6],
		t[7],t[8],t[9],
		t[10],t[11],t[12]
	)

end

--------------------------------------------------
-- SORT PARTS (LAYER BUILD)
--------------------------------------------------

local function SortParts(parts)

	table.sort(parts,function(a,b)

		local ay = a.cf[2]
		local by = b.cf[2]

		if ay ~= by then
			return ay < by
		end

		local ax = a.cf[1]
		local bx = b.cf[1]

		if ax ~= bx then
			return ax < bx
		end

		return a.cf[3] < b.cf[3]

	end)

end

--------------------------------------------------
-- SPAWN BLOCK
--------------------------------------------------

local function SpawnBlock(typeKey,relCF,worldCF)

	local info = BlockTypes[typeKey]

	local args = {
		{
			relCF,
			Attach = "Bottom",
			worldCF,
			info.Color,
			info.Id,
			PurchaseForPlace = true,
			House
		},
		worldCF
	}

	local model = PlaceFurniture:InvokeServer(unpack(args))

	local serial = model:GetAttribute("SerialId")

	return serial

end

--------------------------------------------------
-- RESIZE BLOCK
--------------------------------------------------

local function ResizeBlock(serial,size,worldCF)

	local args = {
		serial,
		House,
		Vector3.new(size[1],size[2],size[3]),
		worldCF
	}

	ChangeSize:InvokeServer(unpack(args))

end

--------------------------------------------------
-- FINALIZE BLOCK
--------------------------------------------------

local function FinalizeBlock(serial,size,worldCF)

	local tempCF = worldCF + Vector3.new(0,0.05,0)

	ResizeBlock(serial,size,tempCF)

	task.wait()

	ResizeBlock(serial,size,worldCF)

end

--------------------------------------------------
-- BUILD
--------------------------------------------------

local function Build()

	local parts = ParseBlueprint(Blueprint)

	local total = #parts

	SortParts(parts)

	local gui,label = CreateProgressGui(total)

	for i,part in ipairs(parts) do

		local relCF = DecodeCF(part.cf)

		local worldCF = GrassCF * relCF

		local serial = SpawnBlock(part.type,relCF,worldCF)

		FinalizeBlock(serial,part.size,worldCF)

		UpdateProgress(label,i,total)

		if i % 20 == 0 then
			task.wait()
		end

	end

	RemoveGui(gui)

end

--------------------------------------------------
-- START
--------------------------------------------------

Build()
