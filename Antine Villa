local ChangeSizeRemote = game:GetService("ReplicatedStorage")
    :WaitForChild("Relays")
    :WaitForChild("House")
    :WaitForChild("ChangeFurnitureSize")

local PlaceFurnitureRemote = game:GetService("ReplicatedStorage")
    :WaitForChild("Relays")
    :WaitForChild("House")
    :WaitForChild("PlaceFurniture")

local TypeMap = {
    Black = "BB_Building Block_Black",
    ["Dark stone grey"] = "BB_Building Block_Dark stone grey",
    ["Dirt brown"] = "BB_Building Block_Dirt brown",
    ["Medium stone grey"] = "BB_Building Block_Medium stone grey",
    White = "BB_Building Block_White",
    Glass = "BB_Glass Pane",
    Grass = "BB_Grass Building Block"
}

local BlockIDs = {
    Blocks = 355,
    Grass = 1167,
    Glass = 959
}

local FixedColors = {
    Grass = "Black",
    Glass = "White"
}

--------------------------------------------------
-- Parse blueprint
--------------------------------------------------
local entries = {}
local remainingCounts = {}
for entry in string.gmatch(Blueprint,"[^;]+") do
    if entry ~= "" then
        local e = {raw=entry, done=false}
        table.insert(entries,e)
        local typeName = string.split(entry,"|")[1]
        remainingCounts[typeName] = (remainingCounts[typeName] or 0) + 1
    end
end

-- GUI labels
local yOffset = 0
for typeName,count in pairs(remainingCounts) do
    if blockFrame then
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1,0,0,30)
        label.Position = UDim2.new(0,0,0,yOffset)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.new(1,1,1)
        label.TextScaled = true
        label.Text = typeName.." X"..count
        label.Parent = blockFrame
        blockLabels[typeName] = label
        yOffset += 35
    end
end

--------------------------------------------------
-- SerialID helper
--------------------------------------------------
local function getSerial(model)
    local serial = model:GetAttribute("SerialId")
    if not serial then return nil end
    return tostring(serial):match("_(%d+)$")
end

--------------------------------------------------
-- Compare part to blueprint
--------------------------------------------------
local function almostEqual(a,b,tol)
    return math.abs(a-b) <= tol
end

local function needsUpdate(part, pos, rot, size)
    local tolerance = 0.1
    local partCF = part.CFrame
    local relCF = OV.Value.Terrain.Grass.CFrame:ToObjectSpace(partCF)
    local rx, ry, rz = relCF:ToEulerAnglesXYZ()

    local posCheck = almostEqual(relCF.Position.X,pos.X,tolerance)
        and almostEqual(relCF.Position.Y,pos.Y,tolerance)
        and almostEqual(relCF.Position.Z,pos.Z,tolerance)

    local rotCheck = almostEqual(math.deg(rx),rot.X,tolerance)
        and almostEqual(math.deg(ry),rot.Y,tolerance)
        and almostEqual(math.deg(rz),rot.Z,tolerance)

    local sizeCheck = almostEqual(part.Size.X,size.X,tolerance)
        and almostEqual(part.Size.Y,size.Y,tolerance)
        and almostEqual(part.Size.Z,size.Z,tolerance)

    return not (posCheck and rotCheck and sizeCheck)
end

--------------------------------------------------
-- Track used SerialIDs
--------------------------------------------------
local usedSerials = {}

--------------------------------------------------
-- Spawn block if none available
--------------------------------------------------
local function spawnBlock(typeName, blueprintPos, blueprintRot)
    local id
    local color = typeName
    if typeName == "Grass" then
        id = BlockIDs.Grass
        color = FixedColors.Grass
    elseif typeName == "Glass" then
        id = BlockIDs.Glass
        color = FixedColors.Glass
    else
        id = BlockIDs.Blocks
    end

    local relCF = CFrame.new(blueprintPos) * CFrame.Angles(
        math.rad(blueprintRot.X),
        math.rad(blueprintRot.Y),
        math.rad(blueprintRot.Z)
    )
    local worldCF = OV.Value.Terrain.Grass.CFrame * relCF

    local args = {
        {
            RelativeCFrame = relCF,
            WorldCFrame = worldCF,
            Color = color,
            Id = id,
            PurchaseForPlace = true,
            House = OV.Value:FindFirstChild("Empty") or OV.Value
        },
        relCF
    }

    PlaceFurnitureRemote:InvokeServer(unpack(args))

    -- wait for the spawned block to appear in furniture
    local modelName = TypeMap[typeName]
    local spawned
    local timeout = tick() + 5
    repeat
        for _, m in ipairs(OV.Value.ActiveAssets.Furniture:GetChildren()) do
            if m.Name == modelName then
                local serial = getSerial(m)
                if serial and not usedSerials[serial] then
                    spawned = m
                    break
                end
            end
        end
        wait(0.1)
    until spawned or tick() > timeout
    return spawned
end

--------------------------------------------------
-- Find model for slot (with spawn fallback)
--------------------------------------------------
local function findModelForSlot(typeName, blueprintPos, blueprintRot)
    local modelName = TypeMap[typeName]
    for _, model in ipairs(OV.Value.ActiveAssets.Furniture:GetChildren()) do
        if model.Name == modelName then
            local serial = getSerial(model)
            if serial and not usedSerials[serial] then
                local part = model:FindFirstChild("Block_Color1")
                if part then
                    usedSerials[serial] = true
                    return model, part, serial
                end
            end
        end
    end
    -- if none found, spawn it
    local spawned = spawnBlock(typeName, blueprintPos, blueprintRot)
    if spawned then
        local part = spawned:FindFirstChild("Block_Color1")
        local serial = getSerial(spawned)
        if part and serial then
            usedSerials[serial] = true
            return spawned, part, serial
        end
    end
    return nil,nil,nil
end

--------------------------------------------------
-- Update GUI counts
--------------------------------------------------
local function updateBlockGUI(typeName)
    local count = remainingCounts[typeName] or 0
    if count <= 0 then
        if blockLabels[typeName] then
            blockLabels[typeName]:Destroy()
            blockLabels[typeName] = nil
        end
    else
        if blockLabels[typeName] then
            blockLabels[typeName].Text = typeName.." X"..count
        end
    end
end

--------------------------------------------------
-- Main loop
--------------------------------------------------
local enabled = false
task.spawn(function()
    while true do
        if enabled then
            for _, entry in ipairs(entries) do
                if not entry.done then
                    local data = string.split(entry.raw,"|")
                    local typeName = data[1]

                    local posTbl = string.split(data[2],",")
                    local rotTbl = string.split(data[3],",")
                    local sizeTbl = string.split(data[4],",")

                    local blueprintPos = Vector3.new(tonumber(posTbl[1]),tonumber(posTbl[2]),tonumber(posTbl[3]))
                    local blueprintRot = Vector3.new(tonumber(rotTbl[1]),tonumber(rotTbl[2]),tonumber(rotTbl[3]))
                    local blueprintSize = Vector3.new(tonumber(sizeTbl[1]),tonumber(sizeTbl[2]),tonumber(sizeTbl[3]))

                    local model, part, SerialID = findModelForSlot(typeName, blueprintPos, blueprintRot)
                    if model and part and SerialID then
                        if needsUpdate(part, blueprintPos, blueprintRot, blueprintSize) then
                            local relCF = CFrame.new(blueprintPos) * CFrame.Angles(
                                math.rad(blueprintRot.X),
                                math.rad(blueprintRot.Y),
                                math.rad(blueprintRot.Z)
                            )
                            local worldCF = OV.Value.Terrain.Grass.CFrame * relCF
                            ChangeSizeRemote:InvokeServer(SerialID, OV.Value, blueprintSize, worldCF)
                        end

                        entry.done = true
                        remainingCounts[typeName] = (remainingCounts[typeName] or 1) - 1
                        updateBlockGUI(typeName)
                    end
                end
            end

            -- check if all done
            local allDone = true
            for _,entry in ipairs(entries) do
                if not entry.done then
                    allDone = false
                    break
                end
            end
            if allDone then
                enabled = false
                toggle.Text = "Blueprint: OFF"
            end
        end
        task.wait(0.05)
    end
end)

