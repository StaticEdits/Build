--====================================================
-- PASTE BLUEPRINT HERE
--====================================================

local blueprintData = [[]]

--====================================================
-- MATERIAL → BLOCK TYPE
--====================================================

local materialMap = {

	Grass = "BB_Grass Building Block",

	Concrete = "BB_Building Block_Medium stone grey",
	Slate = "BB_Building Block_Medium stone grey",

	Wood = "BB_Building Block_Dirt brown",
	WoodPlanks = "BB_Building Block_Dirt brown",

	Granite = "BB_Building Block_Dark stone grey",
	Rock = "BB_Building Block_Dark stone grey",

	SmoothPlastic = "BB_Building Block_White",
	Plastic = "BB_Building Block_White",

	Metal = "BB_Building Block_Black",
	DiamondPlate = "BB_Building Block_Black"

}

local function getBlockType(material)

	if materialMap[material] then
		return materialMap[material]
	end

	return "BB_Building Block_White"

end

--====================================================
-- BLUEPRINT STRUCTURE
--====================================================

local blueprint = {}
local totalRemaining = 0

local function sizeKey(v)

	return math.floor(v.X+0.5)..","..
		   math.floor(v.Y+0.5)..","..
		   math.floor(v.Z+0.5)

end

local function groupKey(size, block)

	return sizeKey(size).."|"..block

end

local function addSlot(size,pos,rot,material)

	local blockType = getBlockType(material)

	local key = groupKey(size,blockType)

	if not blueprint[key] then
		blueprint[key] = {

			size = size,
			blockType = blockType,
			slots = {}

		}
	end

	table.insert(blueprint[key].slots,{

		pos = pos,
		rot = rot,
		filled = false

	})

	totalRemaining += 1

end

--====================================================
-- PARSE BLUEPRINT
--====================================================

for line in blueprintData:gmatch("[^;]+") do

	local part,posStr,rotStr,sizeStr,matStr = line:match("([^|]+)|([^|]+)|([^|]+)|([^|]+)|([^|]+)")

	if part then

		local px,py,pz = posStr:match("([^,]+),([^,]+),([^,]+)")
		local rx,ry,rz = rotStr:match("([^,]+),([^,]+),([^,]+)")
		local sx,sy,sz = sizeStr:match("([^,]+),([^,]+),([^,]+)")

		local pos = Vector3.new(px,py,pz)
		local rot = Vector3.new(rx,ry,rz)
		local size = Vector3.new(sx,sy,sz)

		addSlot(size,pos,rot,matStr)

	end

end

--====================================================
-- CRASH RECOVERY
--====================================================

local function vecClose(a,b,t)

	return math.abs(a.X-b.X)<=t
	and math.abs(a.Y-b.Y)<=t
	and math.abs(a.Z-b.Z)<=t

end

local POSITION_TOL = 0.05
local ROT_TOL = 0.02

local function recover()

	for _,model in ipairs(furnitureFolder:GetChildren()) do

		if not model.Name:find("BB_") then continue end

		local block = model:FindFirstChild("Block_Color1")
		if not block then continue end

		local rel = grass.CFrame:ToObjectSpace(block.CFrame)

		local pos = rel.Position
		local rx,ry,rz = rel:ToOrientation()

		local rot = Vector3.new(rx,ry,rz)

		local size = block.Size

		local key = groupKey(size,model.Name)

		local group = blueprint[key]

		if not group then continue end

		for _,slot in ipairs(group.slots) do

			if slot.filled then continue end

			if vecClose(slot.pos,pos,POSITION_TOL)
			and vecClose(slot.rot,rot,ROT_TOL) then

				slot.filled = true
				totalRemaining -= 1
				break

			end

		end

	end

end

recover()

