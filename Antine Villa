--====================================================
-- GUI UPDATE
--====================================================
local function refreshGUI()
	for _,child in ipairs(frame:GetChildren()) do
		if child:IsA("TextLabel") and child ~= title then
			child:Destroy()
		end
	end

	for _,group in pairs(blueprint) do
		local remaining = 0
		for _,slot in ipairs(group.slots) do
			if not slot.filled then remaining += 1 end
		end
		if remaining > 0 then
			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1,0,0,25)
			label.BackgroundTransparency = 1
			label.TextColor3 = group.blockColor
			label.TextScaled = true
			label.Text = group.colorName.." | "..sizeToKeyGUI(group.size).." x"..remaining
			label.Parent = frame
		end
	end
end

refreshGUI()

--====================================================
-- ADD SIZE TEXT TO PART
--====================================================
local function addSizeText(block)
	if block:FindFirstChild("SizeText") then return end
	local gui = Instance.new("SurfaceGui")
	gui.Name = "SizeText"
	gui.Adornee = block
	gui.Face = Enum.NormalId.Top
	gui.AlwaysOnTop = true
	gui.CanvasSize = Vector2.new(200,50)
	gui.Parent = block

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,1,0)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1,1,1)
	label.TextScaled = true
	label.Text = sizeToKeyGUI(block.Size)
	label.Parent = gui
end

local function removeSizeText(block)
	local gui = block:FindFirstChild("SizeText")
	if gui then gui:Destroy() end
end

--====================================================
-- SLOT ASSIGNMENT
--====================================================
local function assignSlot(block,group)
	for _,slot in ipairs(group.slots) do
		if not slot.filled then
			local relativeCF = CFrame.new(slot.pos) * CFrame.Angles(slot.rot.X,slot.rot.Y,slot.rot.Z)
			block.CFrame = grass.CFrame * relativeCF
			block.Anchored = true
			slot.filled = true
			removeSizeText(block)
			refreshGUI()
			return
		end
	end
end

--====================================================
-- PROCESS MODELS
--====================================================
local function processModel(model)
	local block = model:FindFirstChild("Block_Color1")
	if not block then return end

	for _,group in pairs(blueprint) do
		if model.Name == group.blockName then
			block.Color = group.blockColor
			if block.Size == group.size then
				assignSlot(block,group)
			else
				addSizeText(block)
			end
			break
		end
	end
end

for _,model in ipairs(furnitureFolder:GetChildren()) do
	processModel(model)
end

furnitureFolder.ChildAdded:Connect(processModel)
