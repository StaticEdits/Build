--====================================================
-- COUNT REMAINING
--====================================================

local function getCounts()

	local counts = {}

	for _,group in pairs(blueprint) do

		local remaining = 0

		for _,slot in ipairs(group.slots) do
			if not slot.filled then
				remaining += 1
			end
		end

		if remaining > 0 then

			local key = group.blockType.." "..sizeKey(group.size)

			counts[key] = remaining

		end

	end

	return counts

end

--====================================================
-- GUI UPDATE
--====================================================

local function refresh()

	for _,c in ipairs(container:GetChildren()) do
		if c:IsA("TextLabel") then
			c:Destroy()
		end
	end

	totalLabel.Text = totalRemaining.." parts remaining"

	local counts = getCounts()

	local shown = 0

	for key,count in pairs(counts) do

		if shown >= 5 then break end

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,0,0,25)
		label.BackgroundTransparency = 1
		label.TextColor3 = Color3.new(1,1,1)
		label.TextScaled = true
		label.Text = key.." x"..count
		label.Parent = container

		shown += 1

	end

end

--====================================================
-- SLOT ASSIGNMENT
--====================================================

local function assign(block,modelName)

	local key = groupKey(block.Size,modelName)

	local group = blueprint[key]

	if not group then return end

	for _,slot in ipairs(group.slots) do

		if not slot.filled then

			local cf =
				CFrame.new(slot.pos) *
				CFrame.Angles(slot.rot.X,slot.rot.Y,slot.rot.Z)

			block.CFrame = grass.CFrame * cf
			block.Anchored = true

			slot.filled = true
			totalRemaining -= 1

			refresh()

			return

		end

	end

end

--====================================================
-- MODEL PROCESSING
--====================================================

local function process(model)

	if not model.Name:find("BB_") then return end

	local block = model:WaitForChild("Block_Color1",5)

	if not block then return end

	assign(block,model.Name)

end

for _,m in ipairs(furnitureFolder:GetChildren()) do
	process(m)
end

furnitureFolder.ChildAdded:Connect(process)

refresh()
