--====================================================
-- SIZE HELPERS
--====================================================
local function round1(num)
	return math.floor(num*10 + 0.5)/10
end

local function sizeToKey(size)
	return round1(size.X)..","..round1(size.Y)..","..round1(size.Z)
end

local function sizesMatch(a,b)
	local tol = 0.01
	return math.abs(a.X-b.X)<=tol
	   and math.abs(a.Y-b.Y)<=tol
	   and math.abs(a.Z-b.Z)<=tol
end

local function positionsMatch(a,b)
	local tol = 0.01
	return (a - b).magnitude <= tol
end

local function rotationsMatch(a,b)
	local tol = 0.01
	return math.abs(a.X-b.X)<=tol
	   and math.abs(a.Y-b.Y)<=tol
	   and math.abs(a.Z-b.Z)<=tol
end

--====================================================
-- BLUEPRINT TABLE
--====================================================
local blueprint = {}

local function addSlot(size,pos,rot,material)
	local key = sizeToKey(size).."|"..material
	blueprint[key] = blueprint[key] or {
		size = size,
		material = material,
		blockName = getBlock(material).name,
		blockColor = getBlock(material).color,
		colorName = getBlock(material).colorName,
		slots = {}
	}
	table.insert(blueprint[key].slots,{
		pos = pos,
		rot = rot,
		filled = false
	})
end

--====================================================
-- PARSE BLUEPRINT
--====================================================
for line in blueprintData:gmatch("[^;]+") do
	local part,posStr,rotStr,sizeStr,matStr =
		line:match("([^|]+)|([^|]+)|([^|]+)|([^|]+)|?(.*)")
	if part and posStr and rotStr and sizeStr then
		local px,py,pz = posStr:match("([^,]+),([^,]+),([^,]+)")
		local rx,ry,rz = rotStr:match("([^,]+),([^,]+),([^,]+)")
		local sx,sy,sz = sizeStr:match("([^,]+),([^,]+),([^,]+)")

		local pos = Vector3.new(tonumber(px),tonumber(py),tonumber(pz))
		local rot = Vector3.new(tonumber(rx),tonumber(ry),tonumber(rz))
		local size = Vector3.new(tonumber(sx),tonumber(sy),tonumber(sz))

		if not matStr or matStr == "" then matStr = "SmoothPlastic" end

		addSlot(size,pos,rot,matStr)
	end
end

