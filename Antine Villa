local player = game.Players.LocalPlayer

--------------------------------------------------
-- Robust ParentM auto-detection
--------------------------------------------------
local ParentM = nil
for _, plot in ipairs(workspace.Property.Plots:GetChildren()) do
	-- search recursively for "Owner"
	local ownerValue = plot:FindFirstChild("Owner", true)
	if ownerValue and ownerValue:IsA("StringValue") then
		if ownerValue.Value == player.Name then
			-- find the Empty object under the plot
			ParentM = plot:FindFirstChild("Empty", true) or plot
			break
		end
	end
end

if not ParentM then
	warn("No plot found for player "..player.Name)
	return
end

