local Remote = game:GetService("ReplicatedStorage")
    :WaitForChild("Relays")
    :WaitForChild("House")
    :WaitForChild("ChangeFurnitureSize")

local TypeMap = {
    Black = "BB_Building Block_Black",
    ["Dark stone grey"] = "BB_Building Block_Dark stone grey",
    ["Dirt brown"] = "BB_Building Block_Dirt brown",
    ["Medium stone grey"] = "BB_Building Block_Medium stone grey",
    White = "BB_Building Block_White",
    Glass = "BB_Glass Pane",
    Grass = "BB_Grass Building Block"
}

--------------------------------------------------
-- Parse Blueprint
--------------------------------------------------
local entries = {}
local remainingCounts = {}

for entry in string.gmatch(Blueprint,"[^;]+") do
    if entry ~= "" then
        local e = {raw=entry, done=false}
        table.insert(entries,e)
        local typeName = string.split(entry,"|")[1]
        remainingCounts[typeName] = (remainingCounts[typeName] or 0) + 1
    end
end

-- GUI labels
local yOffset = 0
for typeName,count in pairs(remainingCounts) do
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,30)
    label.Position = UDim2.new(0,0,0,yOffset)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,1,1)
    label.TextScaled = true
    label.Text = typeName.." X"..count
    label.Parent = blockFrame
    blockLabels[typeName] = label
    yOffset += 35
end

--------------------------------------------------
-- SerialID helper
--------------------------------------------------
local function getSerial(model)
    local serial = model:GetAttribute("SerialId")
    if not serial then return nil end
    return tostring(serial):match("_(%d+)$")
end

--------------------------------------------------
-- Compare part to blueprint
--------------------------------------------------
local function almostEqual(a,b,tol)
    return math.abs(a-b) <= tol
end

local function needsUpdate(part, relCF, size)
    local tolerance = 0.1
    local partRel = OV.Value.Terrain.Grass.CFrame:ToObjectSpace(part.CFrame)
    local posCheck = almostEqual(partRel.Position.X, relCF.Position.X,tolerance)
        and almostEqual(partRel.Position.Y, relCF.Position.Y,tolerance)
        and almostEqual(partRel.Position.Z, relCF.Position.Z,tolerance)
    local rotCheck = almostEqual(partRel:ToOrientation(), relCF:ToOrientation(), tolerance)
    local sizeCheck = almostEqual(part.Size.X, size.X, tolerance)
        and almostEqual(part.Size.Y, size.Y, tolerance)
        and almostEqual(part.Size.Z, size.Z, tolerance)
    return not (posCheck and rotCheck and sizeCheck)
end

--------------------------------------------------
-- Track used SerialIDs
--------------------------------------------------
local usedSerials = {}

local function findModelForSlot(typeName)
    local modelName = TypeMap[typeName]
    for _,model in ipairs(OV.Value.ActiveAssets.Furniture:GetChildren()) do
        if model.Name == modelName then
            local serial = getSerial(model)
            if serial and not usedSerials[serial] then
                local part = model:FindFirstChild("Block_Color1")
                if part then
                    usedSerials[serial] = true
                    return model, part, serial
                end
            end
        end
    end
    return nil,nil,nil
end

--------------------------------------------------
-- Update GUI counts
--------------------------------------------------
local function updateBlockGUI(typeName)
    local count = remainingCounts[typeName] or 0
    if count <= 0 then
        if blockLabels[typeName] then
            blockLabels[typeName]:Destroy()
            blockLabels[typeName] = nil
        end
    else
        if blockLabels[typeName] then
            blockLabels[typeName].Text = typeName.." X"..count
        end
    end
end

--------------------------------------------------
-- Main loop
--------------------------------------------------
local enabled = false
task.spawn(function()
    while true do
        if enabled then
            for _,entry in ipairs(entries) do
                if not entry.done then
                    local data = string.split(entry.raw,"|")
                    local typeName = data[1]

                    local model, part, SerialID = findModelForSlot(typeName)
                    if model and part and SerialID then
                        -- Parse relative CFrame
                        local nums = {}
                        for n in string.gmatch(data[2], "[-0-9.]+") do
                            table.insert(nums, tonumber(n))
                        end
                        local relCF = CFrame.new(
                            nums[1], nums[2], nums[3],
                            nums[4], nums[5], nums[6],
                            nums[7], nums[8], nums[9],
                            nums[10], nums[11], nums[12]
                        )

                        -- Parse size
                        local sizeTbl = string.split(data[3], ",")
                        local blueprintSize = Vector3.new(tonumber(sizeTbl[1]), tonumber(sizeTbl[2]), tonumber(sizeTbl[3]))

                        -- Check if needs update
                        if needsUpdate(part, relCF, blueprintSize) then
                            local worldCF = OV.Value.Terrain.Grass.CFrame * relCF
                            local args = {
                                SerialID,
                                OV.Value,
                                blueprintSize,
                                worldCF
                            }
                            Remote:InvokeServer(unpack(args))
                        end

                        -- Mark done and update GUI
                        entry.done = true
                        remainingCounts[typeName] = (remainingCounts[typeName] or 1) - 1
                        updateBlockGUI(typeName)
                    end
                end
            end

            -- Stop when all done
            local allDone = true
            for _,entry in ipairs(entries) do
                if not entry.done then
                    allDone = false
                    break
                end
            end
            if allDone then
                enabled = false
                toggle.Text = "Blueprint: OFF"
            end
        end
        task.wait(0.05)
    end
end)

--------------------------------------------------
-- Toggle
--------------------------------------------------
toggle.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        toggle.Text = "Blueprint: ON"
    else
        toggle.Text = "Blueprint: OFF"
    end
end)
